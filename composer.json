{
    "name": "byu-oit/jwt",
    "description": "JWT decoder/validator for BYU API",
    "license": "MIT",
    "require": {
        "php": "^7.2.5 || ^8.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "php-vcr/phpunit-testlistener-vcr": "^3.3",
        "php-vcr/php-vcr": "^1.5",
        "phpunit/phpunit": "^8.5 || ^9.6"
    },
    "config": {
        "platform": {
            "php": "7.2.5"
        }
    },
    "autoload": {
        "psr-4": {
            "BYU\\JWT\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BYU\\JWT\\Test\\": "tests"
        }
    }
}
